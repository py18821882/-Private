# 数据库
# 本地 Docker PostgreSQL 默认连接
DATABASE_URL="postgresql://admin:admin123@localhost:5432/ai_system?schema=public"

# 站点域名
NEXT_PUBLIC_H5_DOMAIN="https://your-domain.com"
NEXT_PUBLIC_APP_DOMAIN="https://your-domain.com"
NEXT_PUBLIC_API_DOMAIN="https://your-domain.com"
NEXT_PUBLIC_ADMIN_DOMAIN="https://your-domain.com"

# 对外展示名称
NEXT_PUBLIC_PRODUCT_NAME="企业资本合作初步评估"
NEXT_PUBLIC_COMPANY_NAME="中科商业咨询"

# AI 接口
OPENAI_BASE_URL="https://api.deepseek.com"
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"
OPENAI_MODEL="deepseek-chat"
AI_ANALYZE_MODEL="deepseek-chat"
AI_REPORT_MODEL="deepseek-chat"

# 手动收款码
# 可把真实收款码上传到 public/payment-qr.png，然后改成 /payment-qr.png
NEXT_PUBLIC_PAYMENT_QR_URL="/payment-qr.svg"
REPORT_DEFAULT_PRICE=19900

# 管理密码，用于人工确认收款等管理接口
APP_PASSWORD="replace-with-a-strong-password"

# 未来接入真实微信支付时再配置
WECHAT_APP_ID=""
WECHAT_MCH_ID=""
WECHAT_API_KEY=""
WECHAT_NOTIFY_URL=""
WECHAT_CERT_PATH=""

# 可选：企业微信/飞书通知机器人
WECOM_BOT_WEBHOOK=""
FEISHU_BOT_WEBHOOK=""
