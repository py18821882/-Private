# ============================================
# AI 企业增长平台 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
# ============================================

# ===== 数据库配置 =====
# 本地开发使用 SQLite
DATABASE_URL="file:./dev.db"

# 如果使用 PostgreSQL 请改为：
# DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# ===== 域名配置 =====
# H5 前端域名（用户访问地址）
NEXT_PUBLIC_H5_DOMAIN="https://h5.example.com"
# 主站/应用域名
NEXT_PUBLIC_APP_DOMAIN="https://app.example.com"
# API 域名（一般和 H5 同域，Next.js 一体部署）
NEXT_PUBLIC_API_DOMAIN="https://h5.example.com"
# 管理后台域名
NEXT_PUBLIC_ADMIN_DOMAIN="https://admin.example.com"

# ===== AI 模型配置 =====
# OpenAI 兼容 API 基础地址
# DeepSeek: https://api.deepseek.com
# OpenAI: https://api.openai.com/v1
# Kimi: https://api.moonshot.ai/v1
OPENAI_BASE_URL="https://api.deepseek.com"

# API Key（重要：不要泄露到前端！只在服务端使用
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"

# 默认模型
# DeepSeek: deepseek-chat
# OpenAI: gpt-4o-mini / gpt-3.5-turbo
# Kimi: moonshot-v1-8k
OPENAI_MODEL="deepseek-chat"

# 分析用模型（可选，不填用默认）
AI_ANALYZE_MODEL="deepseek-chat"

# 报告生成模型（可选，不填用默认）
AI_REPORT_MODEL="deepseek-chat"

# ===== 微信支付配置 =====
# 微信公众号 AppID
WECHAT_APP_ID="wxxxxxxxxxxxxxxxxxx"

# 微信支付商户号
WECHAT_MCH_ID="1600000000"

# 微信支付 API Key
WECHAT_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 支付回调地址（自动拼接 API 域名）
# 留空则自动使用 NEXT_PUBLIC_API_DOMAIN + /api/payment/wechat/notify
WECHAT_NOTIFY_URL=""

# 微信支付证书路径（退款等需要）
WECHAT_CERT_PATH=""

# ===== 系统配置 =====
# 产品名称
NEXT_PUBLIC_PRODUCT_NAME="企业 AI 增长测评"

# 公司名称
NEXT_PUBLIC_COMPANY_NAME="中科创投"

# 客服微信
NEXT_PUBLIC_SERVICE_WECHAT=""

# 客服电话
NEXT_PUBLIC_SERVICE_PHONE=""

# 报告默认价格（单位：分）
REPORT_DEFAULT_PRICE=19900

# ===== 开发配置 =====
# 是否允许模拟支付（生产环境请设为 false 或删除）
ALLOW_MOCK_PAYMENT=true

# 应用访问密码（middleware.ts 使用）
APP_PASSWORD="admin123"
